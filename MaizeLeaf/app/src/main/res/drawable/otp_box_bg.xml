<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/otp_box_bg.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- State focused (active input) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#EEF2FF" />
            <stroke android:width="2dp" android:color="?attr/colorPrimary" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- State filled (has text) -->
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <stroke android:width="2dp" android:color="#C7D2FE" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FAFAFA" />
            <stroke android:width="2dp" android:color="#E5E7EB" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</selector>