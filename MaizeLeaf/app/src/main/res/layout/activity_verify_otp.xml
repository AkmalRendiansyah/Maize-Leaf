<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="28dp"
    tools:context=".ui.otp.VerifyOtpActivity">

    <!-- Icon -->
    <androidx.cardview.widget.CardView
        android:id="@+id/iconCard"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="22dp"
        app:cardBackgroundColor="#EEF2FF"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_mail_check"
             />
    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/verifikasi_otp"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:letterSpacing="0.01"
        app:layout_constraintTop_toBottomOf="@id/iconCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/kode_otp_6_digit_telah_dikirimkan_ke"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="maizeleaf@gmail.com"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- OTP Input Row -->
    <LinearLayout
        android:id="@+id/otpContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etOtp1"
            style="@style/OtpInputStyle"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etOtp2"
            style="@style/OtpInputStyle"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etOtp3"
            style="@style/OtpInputStyle"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etOtp4"
            style="@style/OtpInputStyle"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etOtp5"
            style="@style/OtpInputStyle"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etOtp6"
            style="@style/OtpInputStyle" />

    </LinearLayout>

    <!-- Verify Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerify"
        android:text="@string/verifikasi"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:backgroundTint="?attr/colorPrimary"
        android:enabled="false"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/otpContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp" />


    <!-- Resend Timer / Button -->
    <LinearLayout
        android:id="@+id/resendContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnVerify"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvResendLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kirim_ulang_dalam"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30s"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Resend Button (hidden initially, shown after countdown) -->
    <LinearLayout
        android:id="@+id/resendButtonContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnVerify"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tidak_menerima_kode"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvResendOtp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kirim_ulang"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            tools:ignore="KeyboardInaccessibleWidget" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>